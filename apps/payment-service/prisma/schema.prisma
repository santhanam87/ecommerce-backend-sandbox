// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Payment {
  id           String        @id @default(uuid())
  userId       String
  transactions Transaction[]
}

model Transaction {
  id              String            @id @default(uuid())
  userId          String
  orderId         String
  authorizationId String
  payment         Payment           @relation(fields: [authorizationId], references: [id])
  status          TransactionStatus @default(AUTHORIZED)
}

enum TransactionStatus {
  AUTHORIZED
  AWAITING_PAYMENT
  PAYMENT_PROCESSED
  FAILED
}
