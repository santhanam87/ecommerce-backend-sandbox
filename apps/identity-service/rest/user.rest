###
# ---- AUTH ----

### Login active user
POST {{baseUrl}}/identity/auth/login
Content-Type: {{contentType}}

{
  "email": "{{userEmail}}",
  "password": "{{userPassword}}"
}

### Refresh tokens
POST {{baseUrl}}/identity/auth/refresh
Content-Type: {{contentType}}

{
  "refresh_token": "{{refreshToken}}"
}

###
# ---- TENANT ----

### Create tenant
POST {{baseUrl}}/identity/auth/tenants
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "tenantName": "Acme Retail",
  "subscriptionType": "premium"
}

### Get all tenants
GET {{baseUrl}}/identity/auth/tenants
Authorization: Bearer {{accessToken}}

###
# ---- USER ----

### Create user
POST {{baseUrl}}/identity/auth/users
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "tenant_id": "{{tenantId}}",
  "email": "{{userEmail}}",
  "password": "{{userPassword}}"
}

### Get all users
GET {{baseUrl}}/identity/auth/users
Authorization: Bearer {{accessToken}}

###
# ---- ROLE ----

### Create role
POST {{baseUrl}}/identity/auth/roles
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "tenant_id": "{{tenantId}}",
  "name": "admin"
}

### Get all roles
GET {{baseUrl}}/identity/auth/roles
Authorization: Bearer {{accessToken}}

###
# ---- ROLE PERMISSION ----

### Create role permission
POST {{baseUrl}}/identity/auth/role-permissions
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "role_id": "{{roleId}}",
  "permission": "product.create",
  "value": {
    "allow": true,
    "scopes": ["all"]
  }
}

### Get all role permissions
GET {{baseUrl}}/identity/auth/role-permissions
Authorization: Bearer {{accessToken}}

### Update role permission value
PATCH {{baseUrl}}/identity/auth/role-permissions/{{rolePermissionId}}/value
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "value": {
    "allow": false,
    "scopes": ["own"]
  }
}

###
# ---- USER ROLE ----

### Create user-role mapping
POST {{baseUrl}}/identity/auth/user-roles
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "user_id": "{{userId}}",
  "role_id": "{{roleId}}"
}

### Get all user-role mappings
GET {{baseUrl}}/identity/auth/user-roles
Authorization: Bearer {{accessToken}}

###
# ---- NOTES ----

### 1. Create a tenant first, then create a user and a role for that tenant.
### 2. Run login and copy access_token and refresh_token into the variables above.
### 3. Use the returned access token for all protected routes.
### 4. Use the created role id for role-permission and user-role requests.
