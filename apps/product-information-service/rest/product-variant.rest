# -----------------------------
# VARIANT CRUD
# -----------------------------

### Create variant
POST {{baseUrl}}/variants
Content-Type: {{contentType}}

{
  "product_id": "{{productId}}",
  "sku": "RUN-SHOE-42-BLK",
  "price": 129.99
}

### Get all variants
GET {{baseUrl}}/variants

### Get variant by id
# Replace with a real UUID from create/list response
@variantId = 22222222-2222-4222-8222-222222222222
GET {{baseUrl}}/variants/{{variantId}}

### Update variant
PATCH {{baseUrl}}/variants/{{variantId}}
Content-Type: {{contentType}}

{
  "sku": "RUN-SHOE-42-BLK-V2",
  "price": 139.99
}

